{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "model": "ollama/qwen3.6:35b-a3b-coding-mxfp8",
  "agent": {
    "build": {
      "model": "ollama/qwen3.6:35b-a3b-coding-mxfp8",
      "temperature": 0.2,
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "ask",
          "ls *": "allow",
