          "grep *": "allow",
          "rg *": "allow",
          "find *": "allow",
          "git status": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "pytest*": "allow",
          "ruff*": "allow",
          "python -m*": "allow"
        }
      }
    }
  }
